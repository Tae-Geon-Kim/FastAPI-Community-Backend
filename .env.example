# .env.example

# 데이터베이스 접속 정보
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=CommunityBackendDB
DB_HOST=127.0.0.1
DB_PORT=5432
DB_MAX_SIZE=10
DB_MIN_SIZE=5

# 폴더 경로
UPLOAD_DIR=upload

# 단일 파일 최대 용량 (예시: 최대 5MB = 5242880)
FILE_MAX_SIZE=5242880

# 게시판에 들어갈 수 있는 파일들의 총합 최대 용량 (예시: 최대 25MB = 25 * 1024 * 1024 = 26214400)
FILE_TOTAL_MAX_SIZE=26214400